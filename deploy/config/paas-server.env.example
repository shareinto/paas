# PaaS 控制面监听地址。
PAAS_HTTP_ADDR=:8080

# 是否在启动 paas-server 前自动执行 MySQL 迁移。
# 本地开发可保持 false；试点和测试环境建议由部署流程显式设置为 true。
PAAS_AUTO_MIGRATE=false

# 业务仓储固定使用 MySQL 正式表；该变量仅保留兼容旧部署脚本，必须为 mysql。
PAAS_REPOSITORY_DRIVER=mysql

# MySQL 连接配置。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=paas
MYSQL_USER=paas
MYSQL_PASSWORD=change-me

# GitLab 源码仓库接入配置。未配置 BaseURL 或 Token 时使用 fake adapter。
GITLAB_BASE_URL=
GITLAB_TOKEN=
GITLAB_ROOT_GROUP_PATH=paas
GITLAB_WEBHOOK_CALLBACK_URL=http://127.0.0.1:8080/api/source-repositories/webhook

# GitOps 清单仓库和平台 Chart 仓库可以使用独立 GitLab。留空时兼容使用 GITLAB_BASE_URL/GITLAB_TOKEN。
GITOPS_GITLAB_BASE_URL=
GITOPS_GITLAB_TOKEN=
GITOPS_GITLAB_TIMEOUT_SECONDS=
GITOPS_GITLAB_RETRY_MAX=
GITLAB_MANIFEST_PROJECT_ID=
GITLAB_MANIFEST_REPO_URL=
GITLAB_CHART_PROJECT_ID=
GITLAB_CHART_REPO_URL=
GITLAB_TIMEOUT_SECONDS=10
GITLAB_RETRY_MAX=2

# 平台标准 Helm Chart。发布时使用 {name}-v{version} tag 固定 Argo CD 引用。
PAAS_PLATFORM_CHART_NAME=paas-app
PAAS_PLATFORM_CHART_VERSION=0.1.0

# Jenkins 构建接入配置。未配置 BaseURL 或 Token 时使用 fake adapter。
JENKINS_BASE_URL=
JENKINS_USERNAME=
JENKINS_TOKEN=
JENKINS_TIMEOUT_SECONDS=10
JENKINS_RETRY_MAX=2
JENKINS_DEFAULT_TEMPLATE_ID=java-unified-v1
JENKINS_CALLBACK_BASE_URL=http://127.0.0.1:8080

# 构建产物镜像仓库前缀，触发构建时会追加应用名称。
IMAGE_REPOSITORY=registry.local/order-api

# 平台统一 Dockerfile 仓库。
DOCKERFILE_REPOSITORY_URL=ssh://git@192.168.100.80:2422/paas/dockerfiles.git
DOCKERFILE_REPOSITORY_REF=main
DOCKERFILE_REPOSITORY_CREDENTIALS_ID=
