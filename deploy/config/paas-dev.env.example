# 复制为 deploy/config/paas-dev.env 后按本机环境修改。

PAAS_HTTP_ADDR=:8080
PAAS_AUTO_MIGRATE=false
PAAS_REPOSITORY_DRIVER=mysql
PAAS_DEV_RECREATE_DB=false
# 留空时：--recreate-db 默认注入开发测试数据，普通启动默认不注入。
PAAS_DEV_SEED_DATA=
PAAS_DEV_SEED_SOURCE_URL=http://192.168.100.80/paas/sbg/macc/log-receiver.git
PAAS_DEV_SEED_SOURCE_SSH_URL=ssh://git@192.168.100.80:2422/paas/sbg/macc/log-receiver.git

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=paas
MYSQL_USER=paas
MYSQL_PASSWORD=change-me

GITLAB_BASE_URL=
GITLAB_TOKEN=
GITLAB_HTTP_URL_ALIASES=http://192.168.100.80
GITLAB_ROOT_GROUP_PATH=paas
GITLAB_WEBHOOK_CALLBACK_URL=

GITOPS_GITLAB_BASE_URL=
GITOPS_GITLAB_TOKEN=
GITOPS_GITLAB_TIMEOUT_SECONDS=
GITOPS_GITLAB_RETRY_MAX=
GITLAB_MANIFEST_PROJECT_ID=
GITLAB_MANIFEST_REPO_URL=
GITLAB_CHART_PROJECT_ID=
GITLAB_CHART_REPO_URL=
GITLAB_TIMEOUT_SECONDS=10
GITLAB_RETRY_MAX=2

PAAS_PLATFORM_CHART_NAME=paas-app
PAAS_PLATFORM_CHART_VERSION=0.1.0

JENKINS_BASE_URL=
JENKINS_USERNAME=
JENKINS_TOKEN=
JENKINS_TIMEOUT_SECONDS=10
JENKINS_RETRY_MAX=2
JENKINS_DEFAULT_TEMPLATE_ID=java-unified-v1
JENKINS_CALLBACK_BASE_URL=http://127.0.0.1:8080

IMAGE_REPOSITORY=registry.local/order-api
DOCKERFILE_REPOSITORY_URL=ssh://git@192.168.100.80:2422/paas/dockerfiles.git
DOCKERFILE_REPOSITORY_REF=main
DOCKERFILE_REPOSITORY_CREDENTIALS_ID=

WEB_HOST=0.0.0.0
WEB_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8080
