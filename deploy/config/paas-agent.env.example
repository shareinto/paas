# Agent 所属集群 ID，必须与控制面 Cluster 记录一致。
PAAS_CLUSTER_ID=cluster_dev

# PaaS 控制面地址，Agent 会主动调用 /api/agent/v1/*。
PAAS_CONTROL_PLANE_URL=http://paas-server.paas-system.svc.cluster.local:8080

# Agent token 由控制面生成和轮换，部署时通过 Secret 注入。
PAAS_AGENT_TOKEN=change-me

# 逗号分隔的采集 namespace。留空表示由运行时按实现默认范围处理。
PAAS_AGENT_NAMESPACES=argocd,order-dev,order-test

# 心跳和状态快照周期。
PAAS_HEARTBEAT_INTERVAL=10s
PAAS_SNAPSHOT_INTERVAL=30s

